# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — never commit real secrets.
#
# In production (e.g. Render), set these as platform environment variables
# instead of shipping a file.
# ---------------------------------------------------------------------------

# ---- Core API -------------------------------------------------------------

# Leave empty to use the SQLite file ./garage.db (local dev).
# In production we run on Neon Postgres — paste the POOLED connection string,
# e.g. postgresql+psycopg://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
# Plain `postgres://` / `postgresql://` is auto-rewritten to the psycopg3 driver.
DATABASE_URL=

# Comma-separated list of allowed CORS origins. "*" allows any origin.
# Lock this down in production to your real admin URL(s).
ALLOWED_ORIGINS=*

# Set this to lock the admin API behind a shared `X-API-Key` header.
# When empty, /vehicles/* is OPEN — fine for local dev only.
# Suggested: openssl rand -hex 32
ADMIN_API_KEY=

# ---- Green-API / WhatsApp -------------------------------------------------

# Per-instance host Green-API assigns you (e.g. https://7107.api.greenapi.com).
# Defaults to the generic api.green-api.com if you leave it blank.
GREEN_API_BASE_URL=https://api.green-api.com

# Numeric instance id from the Green-API console.
GREEN_API_ID_INSTANCE=

# API token associated with the instance above (used for sendMessage).
GREEN_API_TOKEN_INSTANCE=

# Long random string you invent. Paste the SAME value into
# Green-API console -> Instance settings -> "Webhook authorization token".
# When empty the webhook is OPEN — set this in production.
# Suggested: openssl rand -hex 32
GREEN_API_WEBHOOK_TOKEN=

# Master kill-switch for outbound replies. Keep "false" until you've
# verified the inbound webhook works end-to-end; flip to "true" to go live.
WHATSAPP_ENABLED=false

# Outbound HTTP timeout in seconds for calls to Green-API.
WHATSAPP_HTTP_TIMEOUT_SECONDS=10
